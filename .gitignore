# Android native project (generated by `npx cap add android`) — the
# project itself IS committed (manifest/gradle config isn't fully
# regenerable), but build output, local SDK paths, and signing
# credentials are per-machine/secret and must never be committed.
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/captures/
android/*.iml
android/.idea/
*.keystore
*.jks
.vercel
